generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "postgresql"
  url          = env("DATABASE_URL")
  relationMode = "foreignKeys"
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model VerificationToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

model PasswordResetToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

model PaymentInstallment {
  id                String        @id @default(cuid())
  paymentStatusId   String
  amount            Float
  dueDate           DateTime
  paid              Boolean       @default(false)
  installmentNumber Int
  lastReminderSent  DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  paymentStatus     PaymentStatus @relation(fields: [paymentStatusId], references: [id], onDelete: Cascade)
}

model PaymentStatus {
  id                   String                @id @default(cuid())
  status               PaymentStatusType
  courseId             String
  paymentType          String?
  paymentPlan          String?
  cohortId             String?
  userId               String
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  secondPaymentDueDate DateTime?
  desiredStartDate     DateTime?
  changeRequests       ChangeRequest[]
  paymentInstallments  PaymentInstallment[]
  cohort               Cohort?               @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  course               Course                @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions         PaymentTransaction[]
  paystackTransactions PaystackTransaction[]

  @@unique([userId, courseId])
}

model User {
  id                                                                 String                     @id @default(cuid())
  name                                                               String
  email                                                              String?                    @unique
  emailVerified                                                      DateTime?
  image                                                              String?
  password                                                           String?
  role                                                               UserRole                   @default(USER)
  access_token                                                       String?
  phone_number                                                       String?                    @unique
  unlock_free_course_on_data_science                                 Boolean                    @default(false)
  ongoing_courses                                                    String[]
  completed_courses                                                  String[]
  inactive                                                           Boolean                    @default(false)
  createdAt                                                          DateTime                   @default(now())
  updatedAt                                                          DateTime                   @updatedAt
  accountPaymentStatus                                               String?                    @default("UNPAID")
  announcements                                                      Announcement[]
  AssignmentQuizSubmission_AssignmentQuizSubmission_gradedByIdToUser AssignmentQuizSubmission[] @relation("AssignmentQuizSubmission_gradedByIdToUser")
  assignmentQuizSubmissions                                          AssignmentQuizSubmission[]
  gradedSubmissions                                                  AssignmentSubmission[]     @relation("GradedBy")
  assignmentSubmissions                                              AssignmentSubmission[]
  processedChangeRequests                                            ChangeRequest[]            @relation("ProcessedBy")
  changeRequests                                                     ChangeRequest[]            @relation("UserChangeRequests")
  comments                                                           Comment[]
  quiz_leaderboard                                                   Leaderboard[]
  LiveClassAttendance                                                LiveClassAttendance[]
  paymentStatus                                                      PaymentStatus[]
  course_purchased                                                   Purchase[]
  scholarshipApplications                                            ScholarshipApplication[]
  cohorts                                                            UserCohort[]
  completed_videos                                                   UserProgress[]
  quiz_answers                                                       UserQuizAnswer[]
  accounts                                                           Account[]
  streamPost                                                         StreamPost[]
}

model ChangeRequest {
  id              String         @id @default(cuid())
  type            RequestType
  userId          String
  currentCourseId String?
  desiredCourseId String?
  currentCohortId String?
  desiredCohortId String?
  reason          String
  status          RequestStatus  @default(PENDING)
  adminReason     String?
  paymentStatusId String?
  processedById   String?
  processedAt     DateTime?
  paymentDueDate  DateTime?
  paymentLink     String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  currentCohort   Cohort?        @relation("CurrentCohort", fields: [currentCohortId], references: [id])
  currentCourse   Course?        @relation("CurrentCourse", fields: [currentCourseId], references: [id])
  desiredCohort   Cohort?        @relation("DesiredCohort", fields: [desiredCohortId], references: [id])
  desiredCourse   Course?        @relation("DesiredCourse", fields: [desiredCourseId], references: [id])
  paymentStatus   PaymentStatus? @relation(fields: [paymentStatusId], references: [id])
  processedBy     User?          @relation("ProcessedBy", fields: [processedById], references: [id])
  user            User           @relation("UserChangeRequests", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
}

model UserCohort {
  id                   String    @id @default(cuid())
  courseId             String
  cohortId             String
  userId               String
  isPaymentActive      Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  isActive             Boolean   @default(true)
  archivedAt           DateTime?
  previousEnrollmentId String?
  cohort               Cohort    @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, cohortId, courseId])
}

model Cohort {
  id                    String          @id @default(cuid())
  name                  String
  startDate             DateTime        @default(now())
  endDate               DateTime?
  courseId              String
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  currentChangeRequests ChangeRequest[] @relation("CurrentCohort")
  desiredChangeRequests ChangeRequest[] @relation("DesiredCohort")
  course                Course          @relation(fields: [courseId], references: [id], onDelete: Cascade)
  cohortCourses         CohortCourse[]
  paymentStatuses       PaymentStatus[]
  users                 UserCohort[]
}

model CohortCourse {
  id                            String                  @id @default(cuid())
  cohortId                      String
  courseId                      String
  title                         String
  description                   String?
  price                         String?
  imageUrl                      String?
  course_duration               String?
  course_instructor_name        String?
  course_instructor_image       String?
  course_instructor_title       String?
  course_instructor_description String?
  brochureUrl                   String?
  onboardingBrochureUrl         String?
  course_preview_video          String?
  createdAt                     DateTime                @default(now())
  updatedAt                     DateTime                @updatedAt
  announcements                 Announcement[]
  assignments                   Assignment[]
  classMaterial                 ClassMaterial[]
  classRecording                ClassRecording[]
  cohortAttachments             CohortAttachment[]
  cohort                        Cohort                  @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  course                        Course                  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  cohortModules                 CohortCourseModule[]
  cohortTimeTable               CohortCourseTimeTable[]
  cohortWeeks                   CohortCourseWeek[]
  cohortVideos                  CohortProjectVideo[]
  cohortQuizzes                 CohortQuiz[]
  LiveClass                     LiveClass[]
  classroomTopic                ClassroomTopic[]
  streamPost                    StreamPost[]
}

model CohortCourseTimeTable {
  id             String        @id @default(cuid())
  name           String
  category       EventCategory
  date           DateTime
  cohortCourseId String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  cohortCourse   CohortCourse  @relation(fields: [cohortCourseId], references: [id], onDelete: Cascade)
}

model CohortCourseWeek {
  id             String               @id @default(cuid())
  title          String
  iconUrl        String?
  cohortCourseId String
  isPublished    Boolean              @default(false)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  attachments    CohortAttachment[]
  cohortModules  CohortCourseModule[]
  cohortCourse   CohortCourse         @relation(fields: [cohortCourseId], references: [id], onDelete: Cascade)
}

model CohortCourseModule {
  id                  String               @id @default(cuid())
  title               String
  description         String?
  iconUrl             String?
  cohortCourseWeekId  String
  cohortCourseId      String
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  assignments         Assignment[]
  cohortCourse        CohortCourse         @relation(fields: [cohortCourseId], references: [id], onDelete: Cascade)
  cohortCourseWeek    CohortCourseWeek     @relation(fields: [cohortCourseWeekId], references: [id], onDelete: Cascade)
  cohortProjectVideos CohortProjectVideo[]
  cohortQuizzes       CohortQuiz[]
}

model CohortProjectVideo {
  id                   String             @id @default(cuid())
  title                String
  videoUrl             String?
  thumbnailUrl         String?
  duration             String?
  cohortCourseModuleId String
  cohortCourseId       String
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  cohortCourse         CohortCourse       @relation(fields: [cohortCourseId], references: [id], onDelete: Cascade)
  cohortCourseModule   CohortCourseModule @relation(fields: [cohortCourseModuleId], references: [id], onDelete: Cascade)
}

model CohortAttachment {
  id                 String           @id @default(cuid())
  name               String
  url                String?
  cohortCourseWeekId String
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  cohortCourseId     String?
  CohortCourse       CohortCourse?    @relation(fields: [cohortCourseId], references: [id], onDelete: Cascade)
  cohortCourseWeek   CohortCourseWeek @relation(fields: [cohortCourseWeekId], references: [id], onDelete: Cascade)
}

model CohortQuiz {
  id                   String             @id @default(cuid())
  question             String
  cohortCourseModuleId String
  cohortCourseId       String?
  originalQuizId       String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  cohortCourse         CohortCourse?      @relation(fields: [cohortCourseId], references: [id], onDelete: Cascade)
  cohortCourseModule   CohortCourseModule @relation(fields: [cohortCourseModuleId], references: [id], onDelete: Cascade)
  cohortQuizAnswers    CohortQuizAnswer[]
}

model CohortQuizAnswer {
  id               String     @id @default(cuid())
  answer           String
  isCorrect        Boolean
  cohortQuizId     String
  originalAnswerId String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  cohortQuiz       CohortQuiz @relation(fields: [cohortQuizId], references: [id], onDelete: Cascade)
}

model Purchase {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
}

model Course {
  id                                 String               @id @default(cuid())
  title                              String
  description                        String?
  price                              String?
  discount                           String?
  imageUrl                           String?
  slug                               String?
  course_duration                    String?
  course_instructor_name             String?
  course_instructor_image            String?
  course_instructor_title            String?
  course_instructor_description      String?
  course_instructor_ratings          String?
  course_instructor_courses          String?
  course_instructor_lessons          String?
  course_instructor_hrs              String?
  course_instructor_students_trained String?
  brochureUrl                        String?
  course_preview_video               String?
  catalog_header_image               String?
  createdAt                          DateTime             @default(now())
  updatedAt                          DateTime             @updatedAt
  syllabus                           String?
  catalog_header_tags                CatalogHeaderTags[]
  currentChangeRequests              ChangeRequest[]      @relation("CurrentCourse")
  desiredChangeRequests              ChangeRequest[]      @relation("DesiredCourse")
  cohorts                            Cohort[]
  cohortCourses                      CohortCourse[]
  pricingPlans                       CoursePricingPlan[]
  course_weeks                       CourseWeek[]
  learning_Outcomes                  LearningOutcome[]
  paymentStatuses                    PaymentStatus[]
  prerequisites                      Prerequisite[]
  course_videos                      ProjectVideo[]
  purchases                          Purchase[]
  skills_you_will_learn              SkillsYouWillLearn[]
  tags                               Tag[]
  timetable                          TimeTable[]
  facilitators                       Facilitator[]        @relation("CourseToFacilitator")
}

model CoursePricingPlan {
  id                   String @id @default(cuid())
  courseId             String
  planType             String
  amountPerInstallment Float
  installmentsCount    Int
  discountPrice        Float?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  course               Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([courseId, planType])
}

model CourseWeek {
  id            String       @id @default(cuid())
  title         String
  iconUrl       String?
  courseId      String
  isPublished   Boolean      @default(false)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  attachments   Attachment[]
  course        Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseModules Module[]
}

model Attachment {
  id           String     @id @default(cuid())
  name         String
  url          String?
  courseWeekId String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  courseWeek   CourseWeek @relation(fields: [courseWeekId], references: [id], onDelete: Cascade)
}

model Module {
  id            String         @id @default(cuid())
  title         String
  description   String?
  iconUrl       String?
  courseWeekId  String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  CourseWeek    CourseWeek     @relation(fields: [courseWeekId], references: [id], onDelete: Cascade)
  projectVideos ProjectVideo[]
  quizzes       Quiz[]
}

model ProjectVideo {
  id           String   @id @default(cuid())
  title        String
  videoUrl     String?
  thumbnailUrl String?
  duration     String?
  moduleId     String
  courseId     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  videoType    String?  @default("VIMEO")
  course       Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseModule Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
}

model UserProgress {
  id                 String    @id @default(cuid())
  videoId            String
  courseId           String

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  isCompleted         Boolean   @default(false)
  progressPercentage  Float     @default(0)
  lastPositionSeconds Int       @default(0)
  lastWatched         DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, videoId, courseId])
}

model Quiz {
  id           String        @id @default(cuid())
  question     String
  moduleId     String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  leaderboards Leaderboard[]
  courseModule Module        @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  answers      QuizAnswer[]
}

model QuizAnswer {
  id          String           @id @default(cuid())
  name        String
  quizId      String
  isCorrect   Boolean          @default(false)
  quiz        Quiz             @relation(fields: [quizId], references: [id], onDelete: Cascade)
  quizAnswers UserQuizAnswer[]
}

model UserQuizAnswer {
  id           String     @id @default(cuid())
  userId       String
  quizAnswerId String
  quizAnswer   QuizAnswer @relation(fields: [quizAnswerId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, quizAnswerId])
}

model Leaderboard {
  id        String   @id @default(cuid())
  userId    String
  quizId    String
  points    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  quiz      Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, quizId])
}

model TimeTable {
  id        String        @id @default(cuid())
  name      String
  category  EventCategory
  date      DateTime?
  courseId  String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  course    Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model PaystackTransaction {
  id               String         @id @default(cuid())
  transactionRef   String         @unique
  userId           String
  courseId         String
  paymentType      String?
  paymentPlan      String?
  paymentStatusId  String?
  amount           String
  status           String
  paymentDate      DateTime?
  authorizationUrl String?
  metadata         String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  paymentStatus    PaymentStatus? @relation(fields: [paymentStatusId], references: [id])

  @@index([userId])
  @@index([courseId])
  @@index([status])
  @@index([createdAt])
}

model PaymentTransaction {
  id               String         @id @default(cuid())
  transactionRef   String?        @unique
  paymentGateway   PaymentSource
  userId           String
  courseId         String
  paymentType      String?
  paymentPlan      String?
  paymentStatusId  String?
  amount           String
  status           String
  paymentDate      DateTime?
  authorizationUrl String?
  metadata         String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  paymentStatus    PaymentStatus? @relation(fields: [paymentStatusId], references: [id])

  @@index([userId])
  @@index([courseId])
  @@index([status])
  @@index([createdAt])
}

model CatalogHeaderTags {
  id       String  @id @default(cuid())
  title    String
  imageUrl String?
  courseId String
  course   Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model LearningOutcome {
  id       String @id @default(cuid())
  content  String
  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model Prerequisite {
  id       String @id @default(cuid())
  content  String
  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model Tag {
  id       String @id @default(cuid())
  content  String
  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model SkillsYouWillLearn {
  id       String @id @default(cuid())
  iconUrl  String
  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model Blog {
  id        String      @id @default(cuid())
  title     String
  content   String
  mins_read String?     @default("2 mins")
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  images    BlogImage[]
}

model BlogImage {
  id        String   @id @default(cuid())
  url       String?
  blogId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  blog      Blog     @relation(fields: [blogId], references: [id], onDelete: Cascade)
}

model FreeCourseApplication {
  id             String   @id @default(cuid())
  name           String
  email          String
  phone          String
  course_applied String   @default("Data Science")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model MasterClassRegistration {
  id         String   @id @default(cuid())
  name       String
  email      String
  phone      String
  gender     String
  location   String
  heard_from String
  help_with  String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model sessions {
  id          String   @id @default(cuid())
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime
  sessionLink String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([startTime])
  @@index([endTime])
  @@map("sessions")
}

model Facilitator {
  id          String  @id @default(cuid())
  name        String
  email       String  @unique
  phoneNumber String
  imageUrl    String?
  bio         String?
  title       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  courses     Course[] @relation("CourseToFacilitator")
}

model Links {
  id            Int      @id @default(autoincrement())
  communityLink String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("links")
}

model programLeads {
  id          Int       @id @default(autoincrement())
  programType String
  firstName   String
  lastName    String
  email       String
  gender      String
  phoneNumber String
  hearAbout   String?
  otherSource String?
  createdAt   DateTime? @default(now())
  updatedAt   DateTime? @updatedAt
}

model Assignment {
  id                        String                     @id @default(cuid())
  title                     String
  description               String?
  instructions              String?
  dueDate                   DateTime?
  points                    Int?
  type                      AssignmentType             @default(REGULAR)
  cohortCourseId            String
  cohortCourseModuleId      String?
  classroomTopicId          String?
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  isLocked                  Boolean                    @default(false)
  slug                      String?                    @unique
  classroomTopic            ClassroomTopic?            @relation(fields: [classroomTopicId], references: [id], onDelete: Cascade)
  cohortCourse              CohortCourse               @relation(fields: [cohortCourseId], references: [id], onDelete: Cascade)
  cohortCourseModule        CohortCourseModule?        @relation(fields: [cohortCourseModuleId], references: [id], onDelete: Cascade)
  attachments               AssignmentAttachment[]
  assignmentQuizQuestions   AssignmentQuizQuestion[]
  assignmentQuizSubmissions AssignmentQuizSubmission[]
  submissions               AssignmentSubmission[]
}

model AssignmentQuizQuestion {
  id                    String                 @id @default(cuid())
  question              String
  order                 Int                    @default(0)
  points                Int                    @default(1)
  assignmentId          String
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  assignmentQuizAnswers AssignmentQuizAnswer[]
  assignmentQuizOptions AssignmentQuizOption[]
  assignment            Assignment             @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
}

model AssignmentQuizOption {
  id                       String                 @id @default(cuid())
  text                     String
  isCorrect                Boolean                @default(false)
  order                    Int                    @default(0)
  assignmentQuizQuestionId String
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt
  assignmentQuizAnswers    AssignmentQuizAnswer[]
  assignmentQuizQuestion   AssignmentQuizQuestion @relation(fields: [assignmentQuizQuestionId], references: [id], onDelete: Cascade)
}

model AssignmentQuizSubmission {
  id                                             String                 @id @default(cuid())
  assignmentId                                   String
  studentId                                      String
  totalScore                                     Int
  maxScore                                       Int
  submittedAt                                    DateTime               @default(now())
  createdAt                                      DateTime               @default(now())
  updatedAt                                      DateTime               @updatedAt
  feedback                                       String?
  gradedAt                                       DateTime?
  gradedById                                     String?
  assignmentQuizAnswers                          AssignmentQuizAnswer[]
  assignment                                     Assignment             @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  User_AssignmentQuizSubmission_gradedByIdToUser User?                  @relation("AssignmentQuizSubmission_gradedByIdToUser", fields: [gradedById], references: [id])
  student                                        User                   @relation(fields: [studentId], references: [id])

  @@unique([assignmentId, studentId])
}

model AssignmentQuizAnswer {
  id                             String                   @id @default(cuid())
  assignmentQuizSubmissionId     String
  assignmentQuizQuestionId       String
  selectedAssignmentQuizOptionId String
  isCorrect                      Boolean
  pointsEarned                   Int
  createdAt                      DateTime                 @default(now())
  updatedAt                      DateTime                 @updatedAt
  assignmentQuizQuestion         AssignmentQuizQuestion   @relation(fields: [assignmentQuizQuestionId], references: [id], onDelete: Cascade)
  assignmentQuizSubmission       AssignmentQuizSubmission @relation(fields: [assignmentQuizSubmissionId], references: [id], onDelete: Cascade)
  selectedAssignmentQuizOption   AssignmentQuizOption     @relation(fields: [selectedAssignmentQuizOptionId], references: [id], onDelete: Cascade)
}

model AssignmentAttachment {
  id           String     @id @default(cuid())
  name         String
  url          String
  assignmentId String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
}

model AssignmentSubmission {
  id           String     @id @default(cuid())
  content      String?
  fileUrl      String?
  submittedAt  DateTime   @default(now())
  grade        Int?
  feedback     String?
  gradedAt     DateTime?
  gradedById   String?
  assignmentId String
  studentId    String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  gradedBy     User?      @relation("GradedBy", fields: [gradedById], references: [id])
  student      User       @relation(fields: [studentId], references: [id])
  comments     Comment[]

  @@unique([assignmentId, studentId])
}

model Announcement {
  id             String       @id @default(cuid())
  title          String
  content        String
  isPinned       Boolean      @default(false)
  cohortCourseId String
  authorId       String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  author         User         @relation(fields: [authorId], references: [id])
  cohortCourse   CohortCourse @relation(fields: [cohortCourseId], references: [id], onDelete: Cascade)
  comments       Comment[]
}

model Comment {
  id             String                @id @default(cuid())
  content        String
  authorId       String
  announcementId String?
  submissionId   String?
  streamPostId   String?
  parentId       String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  announcement   Announcement?         @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  author         User                  @relation(fields: [authorId], references: [id])
  parent         Comment?              @relation("CommentReplies", fields: [parentId], references: [id])
  replies        Comment[]             @relation("CommentReplies")
  streamPost     StreamPost?           @relation(fields: [streamPostId], references: [id], onDelete: Cascade)
  submission     AssignmentSubmission? @relation(fields: [submissionId], references: [id], onDelete: Cascade)
}

model ClassroomTopic {
  id              String           @id @default(cuid())
  title           String
  description     String?
  isPinned        Boolean          @default(false)
  order           Int              @default(0)
  cohortCourseId  String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  assignments     Assignment[]
  classMaterials  ClassMaterial[]
  classRecordings ClassRecording[]
  LiveClass       LiveClass[]
  cohortCourse    CohortCourse     @relation(fields: [cohortCourseId], references: [id], onDelete: Cascade)

  @@index([cohortCourseId, isPinned, order])
  @@map("classroom_topics")
}

model ClassMaterial {
  id               String          @id @default(cuid())
  title            String
  description      String?
  fileUrl          String?
  fileType         String          @default("pdf")
  imageUrl         String?
  cohortCourseId   String
  classroomTopicId String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  classroomTopic   ClassroomTopic? @relation(fields: [classroomTopicId], references: [id], onDelete: Cascade)
  cohortCourse     CohortCourse    @relation(fields: [cohortCourseId], references: [id], onDelete: Cascade)
}

model ClassRecording {
  id               String          @id @default(cuid())
  title            String
  description      String?
  recordingUrl     String
  cohortCourseId   String
  classroomTopicId String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  classroomTopic   ClassroomTopic? @relation(fields: [classroomTopicId], references: [id], onDelete: Cascade)
  cohortCourse     CohortCourse    @relation(fields: [cohortCourseId], references: [id], onDelete: Cascade)
}

model LiveClass {
  id          String   @id @default(cuid())
  title       String
  description String?
  liveLink    String
  startTime   DateTime
  endTime     DateTime

  notified30m   Boolean @default(false)
  notifiedStart Boolean @default(false)

  cohortCourseId String
  cohortCourse   CohortCourse @relation(fields: [cohortCourseId], references: [id], onDelete: Cascade)

  classroomTopicId String?
  classroomTopic   ClassroomTopic? @relation(fields: [classroomTopicId], references: [id], onDelete: Cascade)

  attendance LiveClassAttendance[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LiveClassAttendance {
  id          String    @id @default(cuid())
  liveClassId String
  liveClass   LiveClass @relation(fields: [liveClassId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  joinedAt DateTime @default(now())

  @@unique([liveClassId, userId])
}

model StreamPost {
  id             String       @id @default(cuid())
  title          String
  content        String
  isPinned       Boolean      @default(false)
  authorId       String
  cohortCourseId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  comments       Comment[]
  author         User         @relation(fields: [authorId], references: [id])
  cohortCourse   CohortCourse @relation(fields: [cohortCourseId], references: [id], onDelete: Cascade)

  @@map("stream_posts")
}

model ScholarshipApplication {
  id            String   @id @default(cuid())
  fullName      String
  email         String
  phone_number  String
  country       String
  gender        String
  program       String
  cohort        String
  discountCode  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  userId        String?
  password      String?
  paymentStatus String   @default("PENDING")
  user          User?    @relation(fields: [userId], references: [id])
}

model WebinarAiAutomation {
  id                  String  @id @default(cuid())
  full_name           String
  email               String
  phone               String
  skill_interested_in String?
  terms_accepted      Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model WebinarGenerativeAiData {
  id                  String  @id @default(cuid())
  full_name           String
  email               String
  phone               String
  skill_interested_in String?
  terms_accepted      Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

